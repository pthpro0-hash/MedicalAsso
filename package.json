{
  "name": "association-doctor-recommendation-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:init": "tsx prisma/init-sqlite.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "smoke": "tsx scripts/smoke.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.10.1",
    "bcryptjs": "^3.0.2",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "pdfkit": "^0.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/sql.js": "^1.4.11",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "prisma": "6.10.1",
    "sql.js": "^1.14.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
